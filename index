            let member = null;
            data.sections.forEach(sec => {
                const line = sec.lines.find(l => l.id === lineId);
                if (line) {
                    member = line.members.find(m => m.id === memberId) || member;
                }
            });
            if (!member) return;
            document.getElementById('edit-lastname').value = member.lastname;
            document.getElementById('edit-firstname').value = member.firstname;
            document.getElementById('edit-role').value = member.role;
            const overlay = document.getElementById('edit-modal-overlay');
            overlay.style.display = 'flex';
        }
        function cancelEditMember() {
            editingLineId = null;
            editingMemberId = null;
            const overlay = document.getElementById('edit-modal-overlay');
            overlay.style.display = 'none';
        }
        function applyEditMember() {
            const ln = document.getElementById('edit-lastname').value.trim();
            const fn = document.getElementById('edit-firstname').value.trim();
            const rl = document.getElementById('edit-role').value.trim();
            if (!ln || !fn || !rl) {
                alert('Veuillez remplir tous les champs.');
                return;
            }
            data.sections.forEach(sec => {
                const line = sec.lines.find(l => l.id === editingLineId);
                if (line) {
                    const member = line.members.find(m => m.id === editingMemberId);
                    if (member) {
                        member.lastname = ln;
                        member.firstname = fn;
                        member.role = rl;
                    }
                }
            });
            cancelEditMember();
            render();
        }

        function exportPDF() {
            const element = document.getElementById('chart-container');
            
            // Show title temporarily
            const title = element.querySelector('.export-title');
            if(title) title.style.display = 'block';

            // Temporarily modify styles to ensure full capture (fix cut-off)
            const originalOverflow = element.style.overflow;
            const originalHeight = element.style.height;
            
            element.style.overflow = 'visible'; // Allow full expansion
            element.style.height = 'auto';      // Remove height limit

            // Hide delete buttons
            const deleteBtns = element.querySelectorAll('.delete-btn, .delete-line-btn');
            deleteBtns.forEach(btn => btn.style.display = 'none');
            
            // Hide account badges during export
            const badges = element.querySelectorAll('.account-badge');
            badges.forEach(b => b.style.display = 'none');

            const opt = {
                margin: 10,
                filename: 'Mon Organigramme.pdf',
                image: { type: 'jpeg', quality: 0.98 },
                html2canvas: { scale: 2, useCORS: true, scrollY: 0 },
                jsPDF: { unit: 'mm', format: 'a4', orientation: 'landscape' }
            };

            // New Promise-based usage:
            html2pdf().set(opt).from(element).save().then(() => {
                // Restore styles
                element.style.overflow = originalOverflow;
                element.style.height = originalHeight;
                
                // Restore buttons (reset inline style to let CSS hover work)
                deleteBtns.forEach(btn => btn.style.display = '');
                
                // Restore badges
                badges.forEach(b => b.style.display = '');

                // Hide title again
                if(title) title.style.display = 'none';
            });
        }

        // --- Rendering ---

        function render() {
            renderLevelsSelect();
            renderChart();
        }

        function renderLevelsSelect() {
            const select = document.getElementById('select-level');
            const currentVal = select.value;
            select.innerHTML = '';

            data.sections.forEach(section => {
                // Optional: Add optgroup if multiple sections
                // const group = document.createElement('optgroup');
                // group.label = section.title;
                
                section.lines.forEach(line => {
                    const option = document.createElement('option');
                    option.value = line.id;
                    option.textContent = `${section.title} - ${line.name}`;
                    select.appendChild(option);
                });
            });

            // Restore selection if possible
            // Simple check: does the value exist in new options?
            let exists = false;
            for(let i=0; i<select.options.length; i++){
                if(select.options[i].value == currentVal) exists = true;
            }

            if (currentVal && exists) {
                select.value = currentVal;
            }
        }

        function renderChart() {
            const container = document.getElementById('chart-container');
            container.innerHTML = '';

            // Header Container (Title + Logos)
            const headerContainer = document.createElement('div');
            headerContainer.className = 'chart-header-container';

            // Title
            const clubName = document.getElementById('input-club-name').value;
            const titleEl = document.createElement('div');
            titleEl.className = 'chart-title';
            titleEl.textContent = clubName;
            
            // Add Title to Header (Order depends on positioning logic below)
            headerContainer.appendChild(titleEl);

            // Add Logos based on Position
            if (currentLogoImage || currentLogoEmoji) {
                if (logoPosition === 'title') {
                    // Flanking the title
                    let leftEl, rightEl;
                    if (currentLogoImage) {
                        leftEl = document.createElement('img');
                        leftEl.src = currentLogoImage;
                        leftEl.className = 'logo-img';
                        rightEl = document.createElement('img');
                        rightEl.src = currentLogoImage;
                        rightEl.className = 'logo-img';
                    } else {
                        leftEl = document.createElement('span');
                        leftEl.className = 'logo-emoji';
                        leftEl.textContent = currentLogoEmoji;
                        rightEl = document.createElement('span');
                        rightEl.className = 'logo-emoji';
                        rightEl.textContent = currentLogoEmoji;
                    }

                    // Re-arrange: Img Title Img
                    headerContainer.innerHTML = '';
                    headerContainer.appendChild(leftEl);
                    headerContainer.appendChild(titleEl);
                    headerContainer.appendChild(rightEl);
                } 
                else if (logoPosition === 'corners') {
                    // Absolute Corners
                    let leftEl, rightEl;
                    if (currentLogoImage) {
                        leftEl = document.createElement('img');
                        leftEl.src = currentLogoImage;
                        leftEl.className = 'logo-img pos-corner left';
                        rightEl = document.createElement('img');
                        rightEl.src = currentLogoImage;
                        rightEl.className = 'logo-img pos-corner right';
                    } else {
                        leftEl = document.createElement('span');
                        leftEl.className = 'logo-emoji pos-corner left';
                        leftEl.textContent = currentLogoEmoji;
                        rightEl = document.createElement('span');
                        rightEl.className = 'logo-emoji pos-corner right';
                        rightEl.textContent = currentLogoEmoji;
                    }
                    headerContainer.appendChild(leftEl);
                    headerContainer.appendChild(rightEl);
                }
                else if (logoPosition === 'bottom') {
                    // Absolute Bottom (of container, not header)
                    // We attach to container later
                }
            }

            container.appendChild(headerContainer);
            if (userStatus === 'gratuit' || userStatus === 'premium') {
                const badge = document.createElement('div');
                badge.className = 'account-badge ' + (userStatus === 'premium' ? 'badge-premium' : 'badge-free');
                badge.textContent = userStatus === 'premium' ? '⭐ Prémium' : 'Gratuit';
                headerContainer.appendChild(badge);
            }

            // Render Sections
            if (data.sections.length === 0) {
                container.innerHTML += '<div>Aucune section.</div>';
                // Don't return, as we might need to render bottom logos
            } else {
                data.sections.forEach(section => {
                    // Create Bubble Container
                    const bubble = document.createElement('div');
                    bubble.className = 'section-bubble';
                    
                    const title = document.createElement('div');
                    title.className = 'section-title';
                    title.textContent = section.title;
                    bubble.appendChild(title);

                    // Render Lines
                    if (section.lines.length === 0) {
                        const empty = document.createElement('div');
                        empty.style.color = '#999';
                        empty.style.textAlign = 'center';
                        empty.textContent = "Aucune ligne dans cette section.";
                        bubble.appendChild(empty);
                    } else {
                        section.lines.forEach(line => {
                            const row = document.createElement('div');
                            row.className = 'level-row';
                            
                            const header = document.createElement('div');
                            header.className = 'level-header';
                            header.textContent = line.name;
                            row.appendChild(header);

                            // Delete Line Button (Visible on hover)
                            const deleteLineBtn = document.createElement('button');
                            deleteLineBtn.className = 'delete-line-btn';
                            deleteLineBtn.innerHTML = '🗑️'; 
                            deleteLineBtn.title = "Supprimer la ligne";
                            deleteLineBtn.onclick = (e) => {
                                e.stopPropagation();
                                removeLine(line.id);
                            };
                            row.appendChild(deleteLineBtn);

                            const membersContainer = document.createElement('div');
                            membersContainer.className = 'members-container';
                            membersContainer.dataset.lineId = line.id;
                            membersContainer.addEventListener('dragenter', function(e){ e.preventDefault(); this.classList.add('drag-over'); });
                            membersContainer.addEventListener('dragover', function(e){ e.preventDefault(); this.classList.add('drag-over'); });
                            membersContainer.addEventListener('dragleave', function(){ this.classList.remove('drag-over'); });
                            membersContainer.addEventListener('drop', function(e){
                                e.preventDefault();
                                this.classList.remove('drag-over');
                                try {
                                    const payload = JSON.parse(e.dataTransfer.getData('text/plain'));
                                    const fromLineId = payload.fromLineId;
                                    const memberId = payload.memberId;
                                    const toLineId = parseInt(this.dataset.lineId);
                                    if (!memberId || !fromLineId || !toLineId) return;
                                    if (fromLineId === toLineId) return;
                                    let moved = null;
                                    data.sections.forEach(sec => {
                                        const fromLine = sec.lines.find(l => l.id === fromLineId);
                                        if (fromLine) {
                                            const idx = fromLine.members.findIndex(m => m.id === memberId);
                                            if (idx !== -1) {
                                                moved = fromLine.members.splice(idx, 1)[0];
                                            }
                                        }
                                    });
                                    if (moved) {
                                        data.sections.forEach(sec => {
                                            const toLine = sec.lines.find(l => l.id === toLineId);
                                            if (toLine) {
                                                toLine.members.push(moved);
                                            }
                                        });
                                        render();
                                    }
                                } catch(_e){}
                            });

                            line.members.forEach(member => {
                                const card = document.createElement('div');
                                card.className = 'member-card';
                                card.draggable = true;
                                card.addEventListener('dragstart', function(e){
                                    e.dataTransfer.setData('text/plain', JSON.stringify({ memberId: member.id, fromLineId: line.id }));
                                });
                                
                                const nameDiv = document.createElement('div');
                                nameDiv.className = 'member-name';
                                if (nameFormat === 'first-last') {
                                    nameDiv.textContent = `${member.firstname} ${member.lastname}`;
                                } else {
                                    nameDiv.textContent = `${member.lastname} ${member.firstname}`;
                                }

                                const roleDiv = document.createElement('div');
                                roleDiv.className = 'member-role';
                                roleDiv.textContent = member.role;
                                
                                const photoInput = document.createElement('input');
                                photoInput.type = 'file';
                                photoInput.accept = 'image/*';
                                photoInput.style.display = 'none';
                                photoInput.onchange = function(ev) {
                                    const file = ev.target.files && ev.target.files[0];
                                    if (!file) return;
                                    const reader = new FileReader();
                                    reader.onload = function(e) {
                                        member.photo = e.target.result;
                                        render();
                                    };
                                    reader.readAsDataURL(file);
                                };
                                
                                if (member.photo) {
                                    const photoEl = document.createElement('img');
                                    photoEl.className = 'member-photo';
                                    photoEl.src = member.photo;
                                    card.appendChild(photoEl);
                                }
                                
                                const actions = document.createElement('div');
                                actions.className = 'member-actions';
                                const editButton = document.createElement('button');
                                editButton.className = 'action-btn edit';
                                editButton.textContent = '✎';
                                editButton.title = 'Modifier';
                                editButton.onclick = () => openEditMember(line.id, member.id);
                                const deleteButton = document.createElement('button');
                                deleteButton.className = 'action-btn delete';
                                deleteButton.textContent = '×';
                                deleteButton.title = 'Supprimer';
                                deleteButton.onclick = () => removeMember(line.id, member.id);
                                const photoButton = document.createElement('button');
                                photoButton.className = 'action-btn photo';
                                photoButton.textContent = '🖼️';
                                photoButton.title = 'Ajouter photo';
                                photoButton.onclick = () => photoInput.click();
                                actions.appendChild(editButton);
                                actions.appendChild(deleteButton);
                                actions.appendChild(photoButton);

                                card.appendChild(nameDiv);
                                card.appendChild(roleDiv);
                                card.appendChild(actions);
                                card.appendChild(photoInput);

                                membersContainer.appendChild(card);
                            });

                            row.appendChild(membersContainer);
                            bubble.appendChild(row);
                        });
                    }
                    container.appendChild(bubble);
                });
            }

            // Render Bottom Logos if needed
            if ((currentLogoImage || currentLogoEmoji) && logoPosition === 'bottom') {
                let leftEl, rightEl;
                if (currentLogoImage) {
                    leftEl = document.createElement('img');
                    leftEl.src = currentLogoImage;
                    leftEl.className = 'logo-img pos-bottom left';
                    rightEl = document.createElement('img');
                    rightEl.src = currentLogoImage;
                    rightEl.className = 'logo-img pos-bottom right';
                } else {
                    leftEl = document.createElement('span');
                    leftEl.className = 'logo-emoji pos-bottom left';
                    leftEl.textContent = currentLogoEmoji;
                    rightEl = document.createElement('span');
                    rightEl.className = 'logo-emoji pos-bottom right';
                    rightEl.textContent = currentLogoEmoji;
                }
                container.appendChild(leftEl);
                container.appendChild(rightEl);
            }

            if (userStatus !== 'premium') {
                const watermark = document.createElement('div');
                watermark.className = 'watermark';
                watermark.innerHTML = 'Corentin BLERVACQUE<br/>free version';
                container.appendChild(watermark);
            }
        }

        // Run
        init();

    </script>
</body>
</html>
